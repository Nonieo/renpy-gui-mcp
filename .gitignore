__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/
dist/
build/

# Ren'Py compiled artifacts inside the fixture project — we want the .rpy
# sources tracked but never the generated .rpyc files.
*.rpyc
*.rpymc
tests/fixtures/*/game/cache/
tests/fixtures/*/game/saves/
tests/fixtures/*/lint.txt
tests/fixtures/*/log.txt
tests/fixtures/*/tmp/

# Frontend
gui/frontend/node_modules/
gui/frontend/dist/
gui/frontend/.vite/
gui/frontend/*.tsbuildinfo

# Editor-metadata sidecars written by `set_canvas_positions` and
# `set_ignored_diagnostics`. Per-author state, not source.
.renpy-mcp/

# Ren'Py distribute output. Lands at `<project>/../<name>-<version>-dists/`;
# keep it out of the repo if anyone runs distribute against a project
# whose parent happens to be the repo root.
*-dists/

# Local secrets, in case anyone drops a .env into this dir. The MCP
# server doesn't read .env itself; this is defense in depth.
.env
.env.local

# Hermes-agent pipeline test artifacts that are pure SDK-template
# scaffold or runtime cache. The meaningful outputs (script.rpy + images)
# are tracked; everything else regenerates from `renpy-mcp new_project`.
games/default/
games/*/game/cache/
games/*/game/saves/
games/*/game/gui/
games/*/game/libs/
games/*/game/gui.rpy
games/*/game/guisupport.rpy
games/*/game/options.rpy
games/*/game/screens.rpy
games/*/log.txt

# Hermes end-to-end test scratch
hermes_run.log
prompt.txt
